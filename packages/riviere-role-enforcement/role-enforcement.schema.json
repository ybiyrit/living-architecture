{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://living-architecture.dev/schemas/role-enforcement.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["include", "ignorePatterns", "layers", "roles"],
  "properties": {
    "include": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ignorePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "layers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paths", "allowedRoles"],
        "properties": {
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowedRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "targets"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["class", "function", "interface", "type-alias"]
            },
            "uniqueItems": true
          },
          "allowedNames": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "nameMatches": {
            "type": "string",
            "minLength": 1
          },
          "allowedInputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "allowedOutputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "forbiddenDependencies": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
