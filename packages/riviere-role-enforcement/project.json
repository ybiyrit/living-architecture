{
  "name": "riviere-role-enforcement",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node esbuild.config.mjs",
          "tsc -p tsconfig.lib.json --emitDeclarationOnly --declaration --declarationDir dist"
        ],
        "cwd": "{projectRoot}",
        "parallel": false
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "smoke-test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node -e \"import('./dist/index.js').then(m => { if (!m.roleEnforcement) process.exit(1) })\""
        ],
        "cwd": "{projectRoot}",
        "parallel": false
      },
      "dependsOn": ["build"]
    }
  }
}
