{
  "name": "@living-architecture/source",
  "targets": {
    "lint-md": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm lint:md",
        "cwd": "{workspaceRoot}"
      }
    },
    "depcruise": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm depcruise",
        "cwd": "{workspaceRoot}"
      }
    },
    "knip": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm knip",
        "cwd": "{workspaceRoot}"
      }
    },
   "role-check": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm exec tsx packages/riviere-role-enforcement/src/shell/bin.ts .riviere/role-enforcement.config.ts",
          "cwd": "{workspaceRoot}"
        }
      }
  }
}
